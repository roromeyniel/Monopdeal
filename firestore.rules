rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomCode} {
      // Anyone can read room data (needed to display game state)
      allow read: if true;

      // Create: authenticated user, sets themselves as host
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'lobby';

      // Update rules with granular checks
      allow update: if request.auth != null && (

        // Host can start the game
        (resource.data.hostId == request.auth.uid
          && request.resource.data.status == 'playing'
          && resource.data.status == 'lobby')

        // Any authenticated user can join lobby
        || (resource.data.status == 'lobby'
          && request.resource.data.status == 'lobby')

        // Players can update during active game
        || (resource.data.status == 'playing'
          && request.auth.uid in resource.data.players)

        // Allow finished state transitions
        || (resource.data.status == 'playing'
          && request.resource.data.status == 'finished'
          && request.auth.uid in resource.data.players)

        // Players can mark themselves connected/disconnected
        || request.auth.uid in resource.data.players
      );
    }
  }
}
